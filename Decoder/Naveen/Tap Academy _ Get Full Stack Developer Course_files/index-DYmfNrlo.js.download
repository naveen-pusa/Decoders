        .inflected-card {
          position: relative;
          border-radius: var(--card-rounding);
          overflow: hidden;
          transition: all 0.3s ease;
        }
        .inflected-cardInner {
          position: relative;
          width: 100%;
          height: 18.75rem;
          background: var(--parent-bg);
          border-radius: var(--card-rounding);
          border-bottom-right-radius: 0;
          overflow: hidden;
          transition: background 0.3s ease;
        }
        .inflected-box {
          width: 100%;
          height: 100%;
          overflow: hidden;
          position: relative;
        }
        .inflected-imgBox {
          position: absolute;
          inset: 0;
          width: 100%;
          height: 100%;
          overflow: hidden;
          border-radius: var(--card-rounding);
        }
        .inflected-icon {
          position: absolute;
          bottom: -0.375rem;
          right: -0.375rem;
          width: 6rem;
          height: 6rem;
          background: var(--parent-bg);
          border-top-left-radius: 50%;
          transition: all 0.3s ease;
        }
        .inflected-icon:hover .inflected-iconBox {
          transform: scale(1.1);
          cursor: pointer;
        }
        .inflected-icon::before {
          position: absolute;
          content: "";
          bottom: 0.375rem;
          left: -1.25rem;
          background: transparent;
          width: 1.25rem;
          height: 1.25rem;
          border-bottom-right-radius: 1.25rem;
          box-shadow: 0.313rem 0.313rem 0 0.313rem var(--parent-bg);
        }
        .inflected-icon::after {
          position: absolute;
          content: "";
          top: -1.25rem;
          right: 0.375rem;
          background: transparent;
          width: 1.25rem;
          height: 1.25rem;
          border-bottom-right-radius: 1.25rem;
          box-shadow: 0.313rem 0.313rem 0 0.313rem var(--parent-bg);
        }
        .inflected-iconBox {
          position: absolute;
          inset: 0.625rem;
          background: var(--button-bg);
          border-radius: 50%;
          display: flex;
          justify-content: center;
          align-items: center;
          transition: all 0.3s ease;
        }
        .inflected-iconBox:hover {
          background: var(--button-hover-bg);
        }
        .inflected-iconBox :global(span) {
          color: var(--icon-color);
          font-size: var(--icon-size);
          transition: color 0.3s ease;
        }
        .inflected-iconBox:hover :global(span) {
          color: var(--icon-hover-color);
        }
        .inflected-content {
          padding: 0.938rem 0.625rem;
        }
        .inflected-content h3 {
          transition: color 0.3s ease;
        }
        .inflected-content p {
          transition: color 0.3s ease;
        }
        .inflected-content ul {
          margin: 0;
          padding: 0;
          list-style-type: none;
          display: flex;
          align-items: center;
          flex-wrap: wrap;
          gap: 0.625rem;
        }
        .inflected-content ul li {
          background: var(--tag-bg);
          color: var(--tag-color);
          font-weight: 700;
          padding: 0.375rem 0.625rem;
          border-radius: var(--tag-rounding);
          transition: all 0.3s ease;
        }
        .inflected-content ul li:hover {
          opacity: 0.8;
        }
      `})]})},CY=({openDemoModal:e})=>{const t=[{id:"frontend-developer",image:rs.domain1,title:"Frontend Developer",description:"Skilled in creating engaging and responsive user interfaces with the latest front-end technologies.",tags:["React","JavaScript","HTML & CSS"]},{id:"backend-developer",image:rs.domain2,title:"Backend Developer",description:"Expert in building robust server-side applications and managing databases to ensure smooth operations.",tags:["Java","Spring Boot","Database"]},{id:"fullstack-developer",image:rs.domain3,title:"Full Stack Developer",description:"Proficient in both front-end and back-end development, capable of handling complete project lifecycles.",tags:["Java Full-Stack","Frontend & Backend","End-to-End"]},{id:"software-engineers",image:rs.domain4,title:"Software Engineers",description:"Versatile professionals with broad experience in software design, development, and optimization.",tags:["Software Design","Algorithms","Optimization"]}];return a.jsx("section",{className:"section-layout--bordered",children:a.jsxs("div",{className:"py-16 content-container container-padding",children:[a.jsx(ne,{direction:"up",delay:0,children:a.jsxs("div",{className:"text-center mb-12 xs:mb-16 sm:mb-20",children:[a.jsx("div",{className:"inline-flex items-center space-x-1.5 xs:space-x-2 bg-[#269BDA]/20 text-[#f5f5f5] px-3 py-1.5 rounded-full text-xs sm:text-sm font-semibold mb-4 xs:mb-6 sm:mb-8 border border-[#269BDA]/30",children:a.jsx("span",{children:"Our Domains"})}),a.jsx("span",{className:"page-heading text-[#f5f5f5] mb-2 block",children:"Tech Domains"}),a.jsx(is,{variant:"primary",size:"lg",children:"We Specialize In"}),a.jsx("p",{className:"text-sm xs:text-base sm:text-lg md:text-xl text-[#f5f5f5]/80 max-w-4xl mx-auto leading-relaxed mt-4",children:"Hire from a range of skilled professionals, including Frontend, Backend, and Full Stack Developers, as well as versatile Software Engineers, all trained in the latest technologies."})]})}),a.jsx(ne,{dir