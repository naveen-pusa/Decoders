ge:yn.p2,name:"Shivanshu Gour",role:"Software Engineer Trainee",package:"5.25 LPA"},{text:"Career switch in just 4 months - couldn't believe it! The mentors prepared me for every possible scenario. From mechanical to software, it was a complete transformation.",image:yn.p3,name:"Vinay Kumar R",role:"Associate Engineer",package:"6.8 LPA"},{text:"Started as a college student with zero coding experience. TAP Academy made me industry-ready in 120 days. The placement support was exceptional throughout.",image:yn.p4,name:"Ponnapalli Durga",role:"Software Engineer Trainee",package:"5.25 LPA"},{text:"The support team is exceptional, guiding us through setup and providing ongoing assistance. From doubt clearing to interview prep, they were always there.",image:yn.p5,name:"Asim Ahmed",role:"Software Engineer Trainee",package:"5.3 LPA"},{text:"Mock interviews were tougher than the real thing! The practical approach and real-world projects set TAP Academy apart from other institutes I considered.",image:yn.p6,name:"Pooja Girish",role:"Software Developer",package:"5 LPA"},{text:"The placement guarantee is real! They lined up interviews until I got my dream job. Highly recommend TAP Academy to anyone serious about their career.",image:yn.p7,name:"Saurabh Kushwaha",role:"Testing Engineer",package:"5 LPA"},{text:"From mechanical engineering to software development - TAP Academy made my career transition smooth and successful. Best decision of my life!",image:yn.p8,name:"Karthik Kukkapalli",role:"Member of Technical Staff",package:"7 LPA"},{text:"The live classes and mentor support made learning enjoyable. Got placed within 3 months of course completion! The community is amazing.",image:yn.p9,name:"Adarsh N Inamdar",role:"Software Developer",package:"7 LPA"},{text:"TAP Academy's industry connections made all the difference. The interview opportunities kept coming until I found the perfect fit for my skills.",image:yn.p11,name:"Anestraj",role:"Software Engineer Trainee",package:"5.35 LPA"},{text:"From a small town to working at a top tech company - TAP Academy made my dreams come true. The mentorship was world-class.",image:yn.p12,name:"Deep Shika",role:"Associate Software analyst",package:"6.8 LPA"},{text:"The practical projects in the curriculum gave me real confidence. When I walked into interviews, I felt prepared for anything they could ask.",image:yn.p13,name:"Rutuja Arun Kokate",role:"Software Engineer Trainee",package:"5.25 LPA"}],[]),{firstColumn:n,secondColumn:s,thirdColumn:r}=f.useMemo(()=>({firstColumn:t.slice(0,4),secondColumn:t.slice(4,8),thirdColumn:t.slice(8,12)}),[t]),i=f.useCallback(()=>{window.location.href="/java-fullstack-details"},[]);return a.jsx(a.Fragment,{children:a.jsxs("div",{className:"min-h-screen bg-[#1c2026]",children:[a.jsx(VK,{openDemoModal:e,onExplore:i}),a.jsx("div",{className:"relative max-w-6xl xl:max-w-[1100px] mx-auto px-4 xs:px-6 sm:px-8 md:px-10 lg:px-12 mt-12",children:a.jsx(ne,{direction:"up",delay:0,children:a.jsx(sr,{componentName:"Stats Section",children:a.jsx(f.Suspense,{fallback:a.jsx(ZK,{}),children:a.jsx(JK,{className:"border-none p-8 sm:p-12",beamsPerSide:4,beamSize:4,beamDuration:4,gridColor:"rgba(38, 155, 218, 0.2)",children:a.jsx(YK,{})})})})})}),a.jsx(FK,{}),a.jsx(HK,{firstColumn:n,secondColumn:s,thirdColumn:r}),a.jsx(qK,{openDemoModal:e,onExplore:i})]})})}const QK=Xl("inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50",{variants:{variant:{default:"bg-primary text-primary-foreground hover:bg-primary/90",destructive:"bg-destructive text-destructive-foreground hover:bg-destructive/90",outline:"border border-input bg-background hover:bg-accent hover:text-accent-foreground",secondary:"bg-secondary text-secondary-foreground hover:bg-secondary/80",ghost:"hover:b