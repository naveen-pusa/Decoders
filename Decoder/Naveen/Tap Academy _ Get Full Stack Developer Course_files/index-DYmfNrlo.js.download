and skilled, making our recruitment process much more efficient.","Exceptional candidates with a strong desire to learn and grow. A pleasure to work with.","The alignment with industry standards in Tap Academy's curriculum is a huge plus for us as employers.","We have had great success with hires from Tap Academy and highly recommend them to other companies."],aJ=["Priya Sharma, HR Manager","Rajesh Kumar, Tech Lead","Anjali Mehta, Sr. Recruiter","Amit Singh, Engineering Manager","Sunita Rao, Director of Talent Acquisition","Vikram Reddy, Software Development Manager","Neha Desai, Technical Recruiter","Sanjay Gupta, Head of Engineering","Deepa Krishnan, HR Business Partner","Arun Verma, Lead Engineer","Meera Iyer, Talent Acquisition Specialist","Rohan Joshi, Technical Lead","Pooja Nair, HR Executive","Alok Verma, CTO","Sonia Patel, Recruitment Manager","Rahul Sharma, Senior Software Engineer","Anita Roy, Head of HR","Karthik Menon, VP of Technology"];function iJ(){return a.jsx(sJ,{title:"What Our Hiring Partners Say",subtitle:"Hear from companies that have successfully hired our graduates",children:a.jsxs(ik,{children:[a.jsxs("div",{className:"relative mx-auto w-full max-w-full sm:max-w-3xl px-4 sm:px-16",children:[a.jsx(ok,{children:Array.from({length:18}).map((e,t)=>a.jsx(lk,{children:a.jsx("div",{className:"px-3 xs:px-4 pb-6 xs:pb-8",children:a.jsxs("div",{className:"text-center rounded-xl border border-[#269BDA]/15 bg-[#1d2229]/60 backdrop-blur-sm p-4 sm:p-6 shadow-[0_4px_20px_rgba(0,0,0,0.25)]",children:[a.jsx("img",{src:"https://d2hqh62t23qj3u.cloudfront.net/assets/logo.svg",alt:"Tap Academy",className:"mx-auto mb-4 h-10 w-10 sm:h-12 sm:w-12"}),a.jsxs("h4",{className:"text-[13px] xs:text-sm sm:text-lg md:text-xl mx-auto max-w-sm sm:max-w-lg px-2 xs:px-4 font-medium text-[#f5f5f5] leading-relaxed italic",children:["“",rJ[t],"”"]}),a.jsx("div",{className:"mt-6 sm:mt-8",children:a.jsx("img",{width:120,height:45,src:Hc[t%Hc.length].url,alt:`${Hc[t%Hc.length].name} 